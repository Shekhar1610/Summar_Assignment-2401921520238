class Solution {
public:
    int largestAltitude(vector<int>& gain) {
        int ans = 0;
        int i = 0;
        int curr = 0;

        while(i < gain.size()){
            int a = curr + gain[i];
            ans = max(ans, a);
            curr = a;
            i++;
        }
        return ans;
    }
};
